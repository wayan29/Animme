# Server
PORT=5000
NODE_ENV=development

# Chromium path used by Puppeteer. Adjust if Chromium is installed elsewhere.
# Common values: /usr/bin/chromium-browser, /usr/bin/chromium, /snap/bin/chromium
PUPPETEER_EXECUTABLE_PATH=/snap/bin/chromium

# Kuramanime / V3 Cloudflare fallback solver.
# Fill these with your own Tertuyul credentials if you want the fallback enabled.
TERTUYUL_API_KEY=
TERTUYUL_PROXY=
TERTUYUL_IN_URL=http://api.tertuyul.my.id/in.php
TERTUYUL_RES_URL=http://api.tertuyul.my.id/res.php

# Optional token for GET /api/hls/sessions when NODE_ENV=production.
HLS_DEBUG_TOKEN=
